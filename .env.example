# Restaurant AI Configuration
# Copy this file to .env and customize for your environment

# ===== Server Settings =====
HOST=0.0.0.0
PORT=8000
DEBUG=False
ENVIRONMENT=development  # development, staging, production

# ===== Restaurant Information =====
RESTAURANT_NAME=The Common House

USE_LOCAL_AI=true
LLAMA_SERVER_URL=http://localhost:8080

# To use template mode instead (fast, instant responses):
# USE_LOCAL_AI=false
# LLAMA_SERVER_URL=

# ===== Security =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production

# ===== CORS Settings =====
# Comma-separated list of allowed origins
# Use "*" for development only!
ALLOWED_ORIGINS=*
# Production example:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===== Logging =====
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/app.log

# =============================================================================
# AI Backend Selection
# =============================================================================
# Controls which engine powers Tobi's responses.
#
# Options:
#   template  Keyword matching only. No model, no AWS account. Instant. Default.
#   llama     Local Llama-3-8B via llama-server (~9 GB RAM, ~15 min cold start).
#   bedrock   AWS Bedrock Claude. No local model. Requires AWS account + setup.
#
# USE_LOCAL_AI and LLAMA_SERVER_URL remain supported for backwards compatibility.
# AI_BACKEND takes precedence when set.
AI_BACKEND=template

# =============================================================================
# AWS Bedrock Settings  (required when AI_BACKEND=bedrock)
# =============================================================================
# Step 1: Request model access — AWS Console → Bedrock → Model access
# Step 2: Set up credentials (see options below)
# Step 3: Set AI_BACKEND=bedrock above
# Full guide: BEDROCK_INTEGRATION.md
#
# --- Region ---
AWS_REGION=us-east-1

# --- Model ---
# Cross-region inference profile: routes to the best available US endpoint.
# Verify this model ID has approved access in your AWS account before using.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Global resilience option (slightly higher latency variance):
# BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# --- Credentials ---
# PRODUCTION (EC2): Attach an IAM role to your instance — leave these blank.
#   boto3 discovers credentials automatically from the instance metadata service.
#   No secrets in any file. See BEDROCK_INTEGRATION.md → Step 1b.
#
# LOCAL DEVELOPMENT — choose one option:
#   Option A (recommended): Run `aws configure` to populate ~/.aws/credentials.
#     The docker-compose.bedrock.yml override mounts ~/.aws into the container.
#   Option B: Uncomment and fill in below (never commit real values):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#   Option C: Use a Bedrock API key (12-hour expiry, no IAM user needed):
#     AWS Console → Bedrock → API keys → Create API key
#     Then set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY to the key values above.
